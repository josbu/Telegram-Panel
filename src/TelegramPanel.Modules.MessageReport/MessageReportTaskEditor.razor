@using System.Text.Json
@using TelegramPanel.Core.Services
@using TelegramPanel.Data.Entities
@inject AccountCategoryManagementService CategoryManagement
@inject AccountManagementService AccountManagement

<MudStack Spacing="2">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        该任务会按账号分类轮流举报指定消息。<b>MaxReports=0</b> 表示持续运行直到你在任务中心手动暂停/停止；如果在外层选择 <b>Cron 计划</b>，建议配合有限次数使用。
    </MudAlert>

    @if (loading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
        <MudText Typo="Typo.caption">正在加载账号分类...</MudText>
    }
    else
    {
        <MudSelect T="int"
                   Label="执行账号分类（可多选）"
                   Variant="Variant.Outlined"
                   Dense="true"
                   MultiSelection="true"
                   SelectedValues="selectedCategoryIds"
                   SelectedValuesChanged="OnSelectedCategoriesChanged"
                   HelperText="会从所有选中分类中抽取可用账号轮流执行举报。">
            @foreach (var category in categories)
            {
                <MudSelectItem Value="@category.Id">@category.Name</MudSelectItem>
            }
        </MudSelect>

        <MudText Typo="Typo.caption" Color="Color.Secondary">
            当前选中分类下可用账号数：@selectedAccountCount
        </MudText>

        <MudTextField @bind-Value="messageReferencesText" @bind-Value:after="OnInputsChanged"
                      Label="消息链接 / 消息引用（每行一个）"
                      Variant="Variant.Outlined"
                      Lines="6"
                      Immediate="true"
                      HelperText="支持：https://t.me/username/123、t.me/c/1234567890/456、用户名/789、-1001234567890/321" />

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="delayMinSeconds" @bind-Value:after="OnInputsChanged"
                                 Label="最小间隔(秒)" Variant="Variant.Outlined" Min="0" Max="600" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="delayMaxSeconds" @bind-Value:after="OnInputsChanged"
                                 Label="最大间隔(秒)" Variant="Variant.Outlined" Min="0" Max="600" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="maxReports" @bind-Value:after="OnInputsChanged"
                                 Label="最多举报次数" Variant="Variant.Outlined" Min="0" Max="1000000"
                                 HelperText="0 表示持续执行直到手动停止。" />
            </MudItem>
        </MudGrid>

        <MudSelect T="string" @bind-Value="reportType" @bind-Value:after="OnInputsChanged"
                   Label="举报类型偏好" Variant="Variant.Outlined" Dense="true">
            <MudSelectItem Value="@MessageReportTaskReportTypes.Spam">垃圾/广告</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Violence">暴力</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Pornography">色情/成人</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.ChildAbuse">儿童/未成年相关</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Copyright">版权/侵权</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.PersonalDetails">隐私/个人信息</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.IllegalDrugs">毒品/违禁药</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Fake">诈骗/冒充/虚假</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Other">其他</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskReportTypes.Auto">自动（取 Telegram 返回的首项）</MudSelectItem>
        </MudSelect>

        <MudTextField @bind-Value="optionKeywordsText" @bind-Value:after="OnInputsChanged"
                      Label="举报选项匹配关键词（可选，每行一个）"
                      Variant="Variant.Outlined"
                      Lines="3"
                      Immediate="true"
                      HelperText="当 Telegram 返回动态举报菜单时，会优先按“举报类型偏好 + 这里的关键词”去匹配选项文本。" />

        <MudTextField @bind-Value="commentsText" @bind-Value:after="OnInputsChanged"
                      Label="举报文案（可选，每行一个）"
                      Variant="Variant.Outlined"
                      Lines="4"
                      Immediate="true"
                      HelperText="仅当 Telegram 要求补充举报说明时才会使用；留空则只在“可跳过评论”时继续。" />

        <MudSelect T="string" @bind-Value="commentMode" @bind-Value:after="OnInputsChanged"
                   Label="举报文案取值模式" Variant="Variant.Outlined" Dense="true">
            <MudSelectItem Value="@MessageReportTaskModes.Queue">队列循环</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskModes.Random">随机</MudSelectItem>
        </MudSelect>
    }
</MudStack>

@code {
    [Parameter] public ModuleTaskDraft Draft { get; set; }
    [Parameter] public EventCallback<ModuleTaskDraft> DraftChanged { get; set; }
    [Parameter] public string? InitialConfigJson { get; set; }

    private List<AccountCategory> categories = new();
    private List<Account> activeAccounts = new();
    private bool loading = true;
    private bool initializedFromConfig;

    private IEnumerable<int> selectedCategoryIds = Array.Empty<int>();
    private string messageReferencesText = string.Empty;
    private int delayMinSeconds = 15;
    private int delayMaxSeconds = 45;
    private int maxReports;
    private string reportType = MessageReportTaskReportTypes.Spam;
    private string optionKeywordsText = string.Empty;
    private string commentsText = string.Empty;
    private string commentMode = MessageReportTaskModes.Queue;

    private int runtimeCompletedAttempts;
    private int runtimeFailedAttempts;
    private int runtimeAccountCursor;
    private int runtimeMessageCursor;
    private int runtimeCommentCursor;
    private List<MessageReportTaskRuntimeFailure> runtimeRecentFailures = new();

    private int selectedAccountCount => activeAccounts.Count(x =>
        x.IsActive
        && x.UserId > 0
        && x.CategoryId.HasValue
        && selectedCategoryIds.Contains(x.CategoryId.Value)
        && x.Category?.ExcludeFromOperations != true);

    protected override async Task OnInitializedAsync()
    {
        ApplyInitialConfigIfNeeded();

        try
        {
            var categoriesTask = CategoryManagement.GetAllCategoriesAsync();
            var accountsTask = AccountManagement.GetAllAccountsAsync();
            await Task.WhenAll(categoriesTask, accountsTask);

            categories = categoriesTask.Result
                .Where(x => !x.ExcludeFromOperations)
                .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();

            activeAccounts = accountsTask.Result.ToList();

            if (!selectedCategoryIds.Any())
            {
                var firstCategoryId = categories.FirstOrDefault()?.Id ?? 0;
                selectedCategoryIds = firstCategoryId > 0 ? new[] { firstCategoryId } : Array.Empty<int>();
            }
        }
        finally
        {
            loading = false;
            await PushDraftAsync();
        }
    }

    private void ApplyInitialConfigIfNeeded()
    {
        if (initializedFromConfig)
            return;

        initializedFromConfig = true;
        var raw = (InitialConfigJson ?? string.Empty).Trim();
        if (raw.Length == 0)
            return;

        try
        {
            var cfg = JsonSerializer.Deserialize<MessageReportTaskConfig>(raw);
            if (cfg == null)
                return;

            var categoryIds = MessageReportTaskInputHelper.NormalizeCategoryIds(cfg.CategoryIds, cfg.CategoryId);
            if (categoryIds.Count > 0)
                selectedCategoryIds = categoryIds;

            messageReferencesText = string.Join(Environment.NewLine, cfg.MessageReferences ?? new List<string>());
            delayMinSeconds = ConvertMillisecondsToSeconds(cfg.DelayMinMs);
            delayMaxSeconds = ConvertMillisecondsToSeconds(cfg.DelayMaxMs);
            maxReports = Math.Max(0, cfg.MaxReports);
            reportType = MessageReportTaskReportTypes.Normalize(cfg.ReportType);
            optionKeywordsText = string.Join(Environment.NewLine, cfg.OptionKeywords ?? new List<string>());
            commentsText = string.Join(Environment.NewLine, cfg.Comments ?? new List<string>());
            commentMode = MessageReportTaskModes.Normalize(cfg.CommentMode);

            runtimeCompletedAttempts = Math.Max(0, cfg.CompletedAttempts);
            runtimeFailedAttempts = Math.Max(0, cfg.FailedAttempts);
            runtimeAccountCursor = Math.Max(0, cfg.AccountCursor);
            runtimeMessageCursor = Math.Max(0, cfg.MessageCursor);
            runtimeCommentCursor = Math.Max(0, cfg.CommentCursor);
            runtimeRecentFailures = cfg.RecentFailures?.TakeLast(20).ToList() ?? new List<MessageReportTaskRuntimeFailure>();
        }
        catch
        {
        }
    }

    private async Task OnSelectedCategoriesChanged(IEnumerable<int> values)
    {
        selectedCategoryIds = MessageReportTaskInputHelper.NormalizeCategoryIds(values, 0);
        await OnInputsChanged();
    }

    private async Task OnInputsChanged()
    {
        await PushDraftAsync();
    }

    private async Task PushDraftAsync()
    {
        var selectedIds = MessageReportTaskInputHelper.NormalizeCategoryIds(selectedCategoryIds, 0);
        var selectedCategories = categories.Where(x => selectedIds.Contains(x.Id)).ToList();
        var messageReferences = MessageReportTaskInputHelper.ParseMultilineText(messageReferencesText, distinct: true);
        var optionKeywords = MessageReportTaskInputHelper.ParseMultilineText(optionKeywordsText, distinct: true);
        var comments = MessageReportTaskInputHelper.ParseMultilineText(commentsText, distinct: false);

        if (loading)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "账号分类加载中"));
            return;
        }

        if (categories.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "没有可用账号分类（或都被标记为排除操作）"));
            return;
        }

        if (selectedCategories.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "请至少选择一个执行账号分类"));
            return;
        }

        if (selectedAccountCount <= 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "所选分类下没有可用执行账号"));
            return;
        }

        if (messageReferences.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "请至少填写一个消息引用"));
            return;
        }

        foreach (var reference in messageReferences)
        {
            if (!MessageReportTaskInputHelper.TryParseMessageReference(reference, out _, out var error))
            {
                await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, $"消息引用无效：{reference}（{error}）"));
                return;
            }
        }

        if (delayMinSeconds < 0 || delayMaxSeconds < 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "间隔不能为负数"));
            return;
        }

        if (delayMaxSeconds < delayMinSeconds)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "最大间隔不能小于最小间隔"));
            return;
        }

        if (maxReports < 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "最多举报次数不能小于 0"));
            return;
        }

        var cfg = new MessageReportTaskConfig
        {
            CategoryId = selectedCategories[0].Id,
            CategoryName = selectedCategories[0].Name,
            CategoryIds = selectedCategories.Select(x => x.Id).ToList(),
            CategoryNames = selectedCategories.Select(x => x.Name).ToList(),
            MessageReferences = messageReferences,
            DelayMinMs = delayMinSeconds * 1000,
            DelayMaxMs = delayMaxSeconds * 1000,
            MaxReports = maxReports,
            ReportType = MessageReportTaskReportTypes.Normalize(reportType),
            OptionKeywords = optionKeywords,
            Comments = comments,
            CommentMode = MessageReportTaskModes.Normalize(commentMode),
            CompletedAttempts = runtimeCompletedAttempts,
            FailedAttempts = runtimeFailedAttempts,
            AccountCursor = runtimeAccountCursor,
            MessageCursor = runtimeMessageCursor,
            CommentCursor = runtimeCommentCursor,
            Canceled = false,
            Error = null,
            RecentFailures = runtimeRecentFailures.ToList()
        };

        var total = maxReports > 0 ? maxReports : 0;
        var json = JsonSerializer.Serialize(cfg, new JsonSerializerOptions { WriteIndented = true });
        await DraftChanged.InvokeAsync(new ModuleTaskDraft(total, json, true, null));
    }

    private static int ConvertMillisecondsToSeconds(int milliseconds)
    {
        if (milliseconds <= 0)
            return 0;
        return (int)Math.Ceiling(milliseconds / 1000d);
    }
}
