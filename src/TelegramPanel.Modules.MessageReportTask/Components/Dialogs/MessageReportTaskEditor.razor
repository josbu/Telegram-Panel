@using System.Text.Json
@using TelegramPanel.Modules.MessageReportTask.Services
@inject AccountCategoryManagementService CategoryManagement

<MudStack Spacing="2">
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Dense="true">
        该任务会按账号分类轮流对指定消息链接执行举报。最多举报次数为 0 表示不设上限，直到所有可用账号-消息组合处理完成或你在任务中心手动停止。
    </MudAlert>

    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
        Telegram 的消息举报是动态选项流程。这里的“举报类型”本质上是匹配 Telegram 返回的选项文字；如果匹配不到，任务会记失败，但不会盲选错误类型。
    </MudAlert>

    @if (loading)
    {
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Small" />
        <MudText Typo="Typo.caption">正在加载账号分类...</MudText>
    }
    else
    {
        <MudSelect T="int"
                   Label="执行账号分类（可多选）"
                   Variant="Variant.Outlined"
                   Dense="true"
                   MultiSelection="true"
                   SelectedValues="selectedCategoryIds"
                   SelectedValuesChanged="OnSelectedCategoriesChanged"
                   HelperText="任务会从所有选中分类中抽取可用账号依次执行举报。">
            @foreach (var c in categories)
            {
                <MudSelectItem Value="@c.Id">@c.Name</MudSelectItem>
            }
        </MudSelect>

        <MudTextField @bind-Value="messageLinksText" @bind-Value:after="OnInputsChanged"
                      Label="消息链接（每行一个）"
                      Variant="Variant.Outlined"
                      Lines="6"
                      Immediate="true"
                      HelperText="支持：https://t.me/username/123、https://t.me/c/123456/789、tg://privatepost?channel=123456&post=789、username/123、-1001234567890/123" />

        <MudGrid>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="delayMinSeconds" @bind-Value:after="OnInputsChanged"
                                 Label="最小间隔(秒)" Variant="Variant.Outlined" Min="0" Max="86400"
                                 HelperText="与最大间隔相同即固定间隔。" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="delayMaxSeconds" @bind-Value:after="OnInputsChanged"
                                 Label="最大间隔(秒)" Variant="Variant.Outlined" Min="0" Max="86400" />
            </MudItem>
            <MudItem xs="12" md="4">
                <MudNumericField T="int" @bind-Value="maxReports" @bind-Value:after="OnInputsChanged"
                                 Label="最多举报次数" Variant="Variant.Outlined" Min="0" Max="1000000"
                                 HelperText="0 表示不限制次数上限。" />
            </MudItem>
        </MudGrid>

        <MudSelect T="string" @bind-Value="reportPreset" @bind-Value:after="OnInputsChanged"
                   Label="举报类型预设" Variant="Variant.Outlined" Dense="true"
                   HelperText="预设会转成关键词去匹配 Telegram 返回的举报选项。">
            <MudSelectItem Value="@MessageReportTaskPresets.Spam">垃圾 / 骚扰</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.Violence">暴力 / 威胁</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.Pornography">色情 / 淫秽</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.ChildAbuse">儿童虐待</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.Copyright">版权侵权</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.IllegalDrugs">违禁药物</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.PersonalDetails">隐私 / 个人信息</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.Other">其他</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.FirstAvailable">直接选第一个选项</MudSelectItem>
            <MudSelectItem Value="@MessageReportTaskPresets.Custom">自定义关键词</MudSelectItem>
        </MudSelect>

        <MudTextField @bind-Value="customKeywordsText" @bind-Value:after="OnInputsChanged"
                      Label="自定义选项关键词（可选，每行一个）"
                      Variant="Variant.Outlined"
                      Lines="4"
                      Immediate="true"
                      HelperText="优先于预设关键词。适合 Telegram 账号语言与预设不一致时手动微调。" />

        <MudTextField @bind-Value="commentText" @bind-Value:after="OnInputsChanged"
                      Label="举报文案（可选）"
                      Variant="Variant.Outlined"
                      Lines="4"
                      Immediate="true"
                      HelperText="当 Telegram 要求补充说明时会自动提交。支持变量：{消息链接}、{聊天标题}、{消息ID}" />
    }
</MudStack>

@code {
    [Parameter] public ModuleTaskDraft Draft { get; set; }
    [Parameter] public EventCallback<ModuleTaskDraft> DraftChanged { get; set; }
    [Parameter] public string? InitialConfigJson { get; set; }

    private List<AccountCategory> categories = new();
    private bool loading = true;
    private bool initializedFromConfig;

    private IEnumerable<int> selectedCategoryIds = Array.Empty<int>();
    private string messageLinksText = string.Empty;
    private int delayMinSeconds = 15;
    private int delayMaxSeconds = 45;
    private int maxReports;
    private string reportPreset = MessageReportTaskPresets.Spam;
    private string customKeywordsText = string.Empty;
    private string commentText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        ApplyInitialConfigIfNeeded();

        try
        {
            categories = (await CategoryManagement.GetAllCategoriesAsync())
                .Where(x => !x.ExcludeFromOperations)
                .OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
                .ToList();

            if (!selectedCategoryIds.Any())
            {
                var firstCategoryId = categories.FirstOrDefault()?.Id ?? 0;
                selectedCategoryIds = firstCategoryId > 0 ? new[] { firstCategoryId } : Array.Empty<int>();
            }
        }
        finally
        {
            loading = false;
            await PushDraftAsync();
        }
    }

    private void ApplyInitialConfigIfNeeded()
    {
        if (initializedFromConfig)
            return;

        initializedFromConfig = true;

        var raw = (InitialConfigJson ?? string.Empty).Trim();
        if (raw.Length == 0)
            return;

        try
        {
            var cfg = JsonSerializer.Deserialize<MessageReportTaskConfig>(raw);
            if (cfg == null)
                return;

            var categoryIds = NormalizeCategoryIds(cfg.CategoryIds, cfg.CategoryId);
            if (categoryIds.Count > 0)
                selectedCategoryIds = categoryIds;

            messageLinksText = string.Join(Environment.NewLine, cfg.MessageLinks ?? new List<string>());
            delayMinSeconds = ConvertMillisecondsToSeconds(cfg.DelayMinMs);
            delayMaxSeconds = ConvertMillisecondsToSeconds(cfg.DelayMaxMs);
            maxReports = Math.Max(0, cfg.MaxReports);
            reportPreset = NormalizePreset(cfg.ReportPreset);
            customKeywordsText = string.Join(Environment.NewLine, cfg.OptionKeywords ?? new List<string>());
            commentText = (cfg.Comment ?? string.Empty).Trim();
        }
        catch
        {
        }
    }

    private async Task OnSelectedCategoriesChanged(IEnumerable<int> values)
    {
        selectedCategoryIds = NormalizeCategoryIds(values, 0);
        await OnInputsChanged();
    }

    private async Task OnInputsChanged()
    {
        await PushDraftAsync();
    }

    private async Task PushDraftAsync()
    {
        var links = ParseLines(messageLinksText, distinct: true);
        var selectedIds = NormalizeCategoryIds(selectedCategoryIds, 0);
        var selectedCategories = categories.Where(x => selectedIds.Contains(x.Id)).ToList();
        var keywords = ParseLines(customKeywordsText, distinct: true);
        var normalizedPreset = NormalizePreset(reportPreset);
        var comment = NormalizeNullableText(commentText);

        if (loading)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "账号分类加载中"));
            return;
        }

        if (categories.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "没有可用账号分类（或都被标记为排除操作）"));
            return;
        }

        if (selectedCategories.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "请至少选择一个执行账号分类"));
            return;
        }

        if (links.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "请至少填写一条消息链接"));
            return;
        }

        if (delayMinSeconds < 0 || delayMaxSeconds < 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "间隔不能为负数"));
            return;
        }

        if (delayMaxSeconds < delayMinSeconds)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "最大间隔不能小于最小间隔"));
            return;
        }

        if (maxReports < 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "最多举报次数不能小于 0"));
            return;
        }

        if (normalizedPreset == MessageReportTaskPresets.Custom && keywords.Count == 0)
        {
            await DraftChanged.InvokeAsync(new ModuleTaskDraft(0, null, false, "选择“自定义关键词”时，至少填写一个关键词"));
            return;
        }

        var categoryNames = selectedCategories.Select(x => x.Name).ToList();
        var cfg = new MessageReportTaskConfig
        {
            CategoryId = selectedCategories[0].Id,
            CategoryName = selectedCategories[0].Name,
            CategoryIds = selectedCategories.Select(x => x.Id).ToList(),
            CategoryNames = categoryNames,
            MessageLinks = links,
            DelayMinMs = delayMinSeconds * 1000,
            DelayMaxMs = delayMaxSeconds * 1000,
            MaxReports = maxReports,
            ReportPreset = normalizedPreset,
            OptionKeywords = keywords,
            Comment = comment
        };

        var total = maxReports > 0 ? maxReports : 0;
        var json = JsonSerializer.Serialize(cfg, new JsonSerializerOptions { WriteIndented = true });
        await DraftChanged.InvokeAsync(new ModuleTaskDraft(total, json, true, null));
    }

    private static List<int> NormalizeCategoryIds(IEnumerable<int>? values, int fallback)
    {
        var ids = (values ?? Array.Empty<int>())
            .Where(x => x > 0)
            .Distinct()
            .ToList();

        if (ids.Count == 0 && fallback > 0)
            ids.Add(fallback);

        return ids;
    }

    private static int ConvertMillisecondsToSeconds(int value)
    {
        if (value <= 0)
            return 0;

        return Math.Max(1, (int)Math.Ceiling(value / 1000d));
    }

    private static string NormalizePreset(string? value)
    {
        var preset = (value ?? string.Empty).Trim().ToLowerInvariant();
        return preset switch
        {
            MessageReportTaskPresets.Spam => MessageReportTaskPresets.Spam,
            MessageReportTaskPresets.Violence => MessageReportTaskPresets.Violence,
            MessageReportTaskPresets.Pornography => MessageReportTaskPresets.Pornography,
            MessageReportTaskPresets.ChildAbuse => MessageReportTaskPresets.ChildAbuse,
            MessageReportTaskPresets.Copyright => MessageReportTaskPresets.Copyright,
            MessageReportTaskPresets.IllegalDrugs => MessageReportTaskPresets.IllegalDrugs,
            MessageReportTaskPresets.PersonalDetails => MessageReportTaskPresets.PersonalDetails,
            MessageReportTaskPresets.Other => MessageReportTaskPresets.Other,
            MessageReportTaskPresets.FirstAvailable => MessageReportTaskPresets.FirstAvailable,
            MessageReportTaskPresets.Custom => MessageReportTaskPresets.Custom,
            _ => MessageReportTaskPresets.Spam
        };
    }

    private static List<string> ParseLines(string? text, bool distinct)
    {
        if (string.IsNullOrWhiteSpace(text))
            return new List<string>();

        var values = text
            .Split(new[] { "\r\n", "\n", "\r" }, StringSplitOptions.RemoveEmptyEntries)
            .Select(x => (x ?? string.Empty).Trim())
            .Where(x => x.Length > 0);

        return distinct
            ? values.Distinct(StringComparer.OrdinalIgnoreCase).ToList()
            : values.ToList();
    }

    private static string? NormalizeNullableText(string? value)
    {
        var text = (value ?? string.Empty).Trim();
        return text.Length == 0 ? null : text;
    }
}
